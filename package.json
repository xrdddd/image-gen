{
  "name": "image-generate-app",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --no-dev --minify",
    "start:dev": "expo start",
    "android": "expo run:android",
    "ios": "ulimit -n 4096 && expo run:ios",
    "ios:device": "ulimit -n 4096 && expo run:ios --device",
    "web": "expo start --web",
    "build:ios": "npx eas-cli build --platform ios",
    "build:android": "npx eas-cli build --platform android",
    "submit:ios": "npx eas-cli submit --platform ios",
    "submit:android": "npx eas-cli submit --platform android",
    "eas:configure": "npx eas-cli build:configure",
    "download-model": "python3 scripts/download_model.py",
    "download-mlpackage": "python3 scripts/download_mlpackage.py",
    "quantize-models": "python3 scripts/quantize_models.py",
    "quantize-mlpackage": "python3 scripts/quantize_mlpackage.py",
    "quantize-int8": "python3 scripts/quantize_to_int8.py",
    "clear-certificate": "bash scripts/clear_certificate.sh",
    "fix-provisioning": "bash scripts/fix_provisioning.sh",
    "fix-native-module": "bash scripts/fix_native_module.sh",
    "postinstall": "patch-package",
    "start:ios": "ulimit -n 4096 && expo start --ios",
    "start:android": "ulimit -n 4096 && expo start --android",
    "fix-watcher": "bash fix-watcher.sh",
    "start:clean": "bash fix-watcher.sh && npm start",
    "prebuild:ios": "npx expo prebuild --platform ios",
    "open:xcode": "open ios/*.xcworkspace 2>/dev/null || open ios/*.xcodeproj 2>/dev/null || echo 'Run: npm run prebuild:ios first'",
    "build:xcode": "bash scripts/use_xcode_build.sh"
  },
  "dependencies": {
    "expo": "~50.0.0",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-safe-area-context": "4.8.2",
    "expo-image": "~1.10.0",
    "expo-linear-gradient": "~12.7.0",
    "@react-native-async-storage/async-storage": "1.21.0",
    "expo-constants": "~15.4.0",
    "expo-image-picker": "~14.7.1",
    "expo-dev-client": "~3.3.0",
    "expo-file-system": "~16.0.6",
    "expo-asset": "~9.0.0",
    "react-native-fs": "^2.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "typescript": "^5.1.3",
    "eas-cli": "^5.0.0",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0"
  },
  "private": true
}
